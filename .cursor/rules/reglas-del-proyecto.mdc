# Frontend Rules - Clean Architecture Adaptada (SaaS)

## Stack Tecnológico
- **Framework**: Next.js 14+ con App Router (`src/app`)
- **UI/Styling**: Tailwind CSS
- **State Management**: Zustand para estado global + useState/useEffect para estado local
- **Forms**: React Hook Form
- **Data Fetching**: fetch directo encapsulado (`customFetch`)
- **Lenguaje**: TypeScript estricto

---

## Arquitectura: Clean Architecture Adaptada para Frontend

### Estructura de Carpetas Obligatoria

```
src/
├── app/                    # Next.js App Router (solo rutas y layouts)
│   ├── (auth)/
│   ├── (dashboard)/
│   └── layout.tsx
├── core/                   # DOMINIO (lógica de negocio pura)
│   ├── entities/          # Modelos de dominio (interfaces/types)
│   ├── use-cases/         # Casos de uso (lógica de negocio)
│   └── ports/             # Interfaces para servicios externos
├── infrastructure/         # ADAPTADORES (implementaciones concretas)
│   ├── api/               # Llamadas HTTP (customFetch, endpoints)
│   ├── storage/           # LocalStorage, cookies, IndexedDB
│   └── services/          # Implementaciones de ports
├── presentation/           # CAPA DE PRESENTACIÓN
│   ├── components/        # Componentes reutilizables UI
│   │   ├── ui/           # Componentes base (Button, Input, Card)
│   │   └── features/     # Componentes de negocio (UserProfile, PaymentForm)
│   ├── hooks/            # Custom hooks (lógica de presentación)
│   ├── stores/           # Zustand stores
│   └── utils/            # Helpers de UI (formatters, validators)
└── config/                # Configuración (env, constants)
```

---

## Principios SOLID Aplicados

### 1. Single Responsibility Principle (SRP)
```tsx
// ❌ MAL: Componente con múltiples responsabilidades
function UserDashboard() {
  const [user, setUser] = useState(null);
  const [loading, setLoading] = useState(false);
  
  useEffect(() => {
    fetch('/api/user').then(res => res.json()).then(setUser);
  }, []);
  
  return <div>{/* UI + lógica mezclada */}</div>;
}

// ✅ BIEN: Responsabilidades separadas
// core/use-cases/getUser.ts
export async function getUser(userId: string): Promise<User> {
  const response = await customFetch(`/api/users/${userId}`);
  return response.data;
}

// presentation/hooks/useUser.ts
export function useUser(userId: string) {
  const [user, setUser] = useState<User | null>(null);
  const [loading, setLoading] = useState(false);
  
  useEffect(() => {
    setLoading(true);
    getUser(userId)
      .then(setUser)
      .finally(() => setLoading(false));
  }, [userId]);
  
  return { user, loading };
}

// presentation/components/features/UserDashboard.tsx
export function UserDashboard({ userId }: Props) {
  const { user, loading } = useUser(userId);
  
  if (loading) return <Spinner />;
  return <UserCard user={user} />;
}
```

### 2. Open/Closed Principle (OCP)
```tsx
// ✅ BIEN: Extensible sin modificar código existente
// core/ports/IPaymentGateway.ts
export interface IPaymentGateway {
  processPayment(amount: number, method: PaymentMethod): Promise<PaymentResult>;
}

// infrastructure/services/StripePaymentGateway.ts
export class StripePaymentGateway implements IPaymentGateway {
  async processPayment(amount: number, method: PaymentMethod) {
    // Implementación Stripe
  }
}

// infrastructure/services/PayPalPaymentGateway.ts
export class PayPalPaymentGateway implements IPaymentGateway {
  async processPayment(amount: number, method: PaymentMethod) {
    // Implementación PayPal (nueva sin romper código existente)
  }
}
```

### 3. Liskov Substitution Principle (LSP)
```tsx
// ✅ BIEN: Todos los botones son intercambiables
interface ButtonProps {
  onClick: () => void;
  children: React.ReactNode;
  disabled?: boolean;
}

function PrimaryButton(props: ButtonProps) { /* ... */ }
function SecondaryButton(props: ButtonProps) { /* ... */ }
function DangerButton(props: ButtonProps) { /* ... */ }

// Cualquiera puede usarse sin romper el contrato
<PrimaryButton onClick={handleSave}>Guardar</PrimaryButton>
<DangerButton onClick={handleDelete}>Eliminar</DangerButton>
```

### 4. Interface Segregation Principle (ISP)
```tsx
// ❌ MAL: Interface gigante que obliga a implementar todo
interface IUserService {
  getUser(): Promise<User>;
  updateUser(): Promise<void>;
  deleteUser(): Promise<void>;
  sendEmail(): Promise<void>;
  validatePermissions(): boolean;
}

// ✅ BIEN: Interfaces pequeñas y específicas
interface IUserReader {
  getUser(id: string): Promise<User>;
}

interface IUserWriter {
  updateUser(id: string, data: Partial<User>): Promise<void>;
  deleteUser(id: string): Promise<void>;
}

interface INotificationSender {
  sendEmail(to: string, message: string): Promise<void>;
}
```

### 5. Dependency Inversion Principle (DIP)
```tsx
// ✅ BIEN: Dependemos de abstracciones, no de implementaciones concretas
// core/use-cases/registerUser.ts
export async function registerUser(
  userData: UserRegistration,
  authService: IAuthService,  // ← Port (abstracción)
  emailService: IEmailService  // ← Port (abstracción)
) {
  const user = await authService.createUser(userData);
  await emailService.sendWelcomeEmail(user.email);
  return user;
}

// infrastructure/services/FirebaseAuthService.ts
export class FirebaseAuthService implements IAuthService {
  async createUser(data: UserRegistration) { /* ... */ }
}

// presentation/hooks/useRegisterUser.ts
export function useRegisterUser() {
  const authService = new FirebaseAuthService(); // Inyección
  const emailService = new SendGridEmailService();
  
  return (data: UserRegistration) => registerUser(data, authService, emailService);
}
```

