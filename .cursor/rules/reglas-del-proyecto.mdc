## Reglas de Código Obligatorias

### 1. Naming Conventions
```tsx
// Componentes: PascalCase
export function UserProfileCard() {}

// Hooks: camelCase con prefijo 'use'
export function useUserProfile() {}

// Constantes: UPPER_SNAKE_CASE
export const MAX_FILE_SIZE = 5_000_000;

// Funciones/variables: camelCase
const calculateTotal = (items: Item[]) => {};

// Tipos/Interfaces: PascalCase con prefijo 'I' para interfaces
export interface IUserRepository {}
export type User = {};
```

### 2. Tipado Estricto
```tsx
// ✅ BIEN: Tipos explícitos siempre
interface UserCardProps {
  user: User;
  onEdit: (userId: string) => void;
  className?: string;
}

export function UserCard({ user, onEdit, className }: UserCardProps) {
  // ...
}

// ❌ MAL: any o tipos implícitos
function UserCard({ user, onEdit }: any) {}
```

### 3. Manejo de Errores
```tsx
// ✅ BIEN: Try-catch en casos de uso + feedback UI
// core/use-cases/createProject.ts
export async function createProject(data: ProjectData): Promise<Result<Project>> {
  try {
    const response = await customFetch('/api/projects', {
      method: 'POST',
      body: JSON.stringify(data)
    });
    return { success: true, data: response.data };
  } catch (error) {
    return { 
      success: false, 
      error: error instanceof Error ? error.message : 'Error desconocido' 
    };
  }
}

// presentation/hooks/useCreateProject.ts
export function useCreateProject() {
  const [loading, setLoading] = useState(false);
  
  const create = async (data: ProjectData) => {
    setLoading(true);
    const result = await createProject(data);
    setLoading(false);
    
    if (!result.success) {
      toast.error(result.error);
      return null;
    }
    
    toast.success('Proyecto creado');
    return result.data;
  };
  
  return { create, loading };
}
```

### 4. Separación de Concerns
```tsx
// ❌ MAL: Lógica de negocio en componente
function ProductList() {
  const [products, setProducts] = useState([]);
  
  useEffect(() => {
    fetch('/api/products')
      .then(res => res.json())
      .then(data => {
        // Lógica de negocio aquí ❌
        const filtered = data.filter(p => p.stock > 0);
        const sorted = filtered.sort((a, b) => b.price - a.price);
        setProducts(sorted);
      });
  }, []);
  
  return <div>{/* ... */}</div>;
}

// ✅ BIEN: Lógica en caso de uso
// core/use-cases/getAvailableProducts.ts
export async function getAvailableProducts(): Promise<Product[]> {
  const response = await customFetch('/api/products');
  const products = response.data;
  
  return products
    .filter(p => p.stock > 0)
    .sort((a, b) => b.price - a.price);
}

// presentation/hooks/useProducts.ts
export function useProducts() {
  const [products, setProducts] = useState<Product[]>([]);
  const [loading, setLoading] = useState(true);
  
  useEffect(() => {
    getAvailableProducts()
      .then(setProducts)
      .finally(() => setLoading(false));
  }, []);
  
  return { products, loading };
}

// presentation/components/features/ProductList.tsx
export function ProductList() {
  const { products, loading } = useProducts();
  
  if (loading) return <Skeleton />;
  return <ProductGrid products={products} />;
}
```

### 5. Zustand Stores
```tsx
// ✅ BIEN: Store con acciones y estado separados
// presentation/stores/authStore.ts
import { create } from 'zustand';
import { loginUser, logoutUser } from '@/core/use-cases/auth';

interface AuthState {
  user: User | null;
  isAuthenticated: boolean;
  loading: boolean;
  
  // Actions
  login: (email: string, password: string) => Promise<void>;
  logout: () => Promise<void>;
  setUser: (user: User | null) => void;
}

export const useAuthStore = create<AuthState>((set) => ({
  user: null,
  isAuthenticated: false,
  loading: false,
  
  login: async (email, password) => {
    set({ loading: true });
    const result = await loginUser(email, password);
    
    if (result.success) {
      set({ user: result.data, isAuthenticated: true, loading: false });
    } else {
      set({ loading: false });
      throw new Error(result.error);
    }
  },
  
  logout: async () => {
    await logoutUser();
    set({ user: null, isAuthenticated: false });
  },
  
  setUser: (user) => set({ user, isAuthenticated: !!user })
}));
```

### 6. React Hook Form
```tsx
// ✅ BIEN: Validación con Zod + tipado
import { useForm } from 'react-hook-form';
import { zodResolver } from '@hookform/resolvers/zod';
import * as z from 'zod';

const registerSchema = z.object({
  email: z.string().email('Email inválido'),
  password: z.string().min(8, 'Mínimo 8 caracteres'),
  name: z.string().min(2, 'Nombre requerido')
});

type RegisterFormData = z.infer<typeof registerSchema>;

export function RegisterForm() {
  const { register, handleSubmit, formState: { errors } } = useForm<RegisterFormData>({
    resolver: zodResolver(registerSchema)
  });
  
  const onSubmit = async (data: RegisterFormData) => {
    // Caso de uso
    await registerUser(data);
  };
  
  return (
    <form onSubmit={handleSubmit(onSubmit)}>
      <input {...register('email')} />
      {errors.email && <span>{errors.email.message}</span>}
      {/* ... */}
    </form>
  );
}
```

